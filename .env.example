############################################################
# Frontend Supabase configuration
############################################################

# Public URL of your Supabase project
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Public (anon) key of your Supabase project
# You can copy it from Project Settings → API → anon public
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"


############################################################
# AI providers – reference for local usage
# IMPORTANT: For production, set these as Supabase secrets
#           for the Edge Functions, NOT only in this file.
############################################################

# Google Gemini API key
GEMINI_API_KEY="your-gemini-api-key"

# OpenRouter API key (optional alternative provider)
OPENROUTER_API_KEY="your-openrouter-api-key"

# Optional: default model for OpenRouter
# Example: google/gemini-2.5-flash, anthropic/claude-3.5-sonnet, etc.
OPENROUTER_MODEL="google/gemini-2.5-flash"

# Optional: used as HTTP-Referer when calling OpenRouter
SITE_URL="http://localhost:8080"


############################################################
# Notes
############################################################

# 1. This file should NOT contain real secrets in git.
#    Replace placeholders locally and keep your real values
#    only in untracked .env / .env.local files.
#
# 2. For Supabase Edge Functions to work in production you MUST
#    set the same keys as Supabase project secrets:
#
#    supabase secrets set GEMINI_API_KEY=...
#    supabase secrets set OPENROUTER_API_KEY=...
#
# 3. Frontend uses only VITE_* variables at build time.

